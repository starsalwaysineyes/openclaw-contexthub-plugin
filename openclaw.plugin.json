{
  "id": "openclaw-contexthub-plugin",
  "name": "OpenClaw Ctx Plugin",
  "description": "A single /ctx command and ctx tool for local filesystem paths and ContextHub ctx:// cloud filesystem operations.",
  "version": "0.2.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "baseUrl": { "type": "string" },
      "token": { "type": "string" },
      "defaultUserId": { "type": "string" },
      "localRoot": { "type": "string" },
      "timeoutMs": { "type": "number" }
    }
  },
  "uiHints": {
    "baseUrl": { "label": "ContextHub Base URL", "placeholder": "http://38.55.39.92:24040" },
    "token": { "label": "Bearer Token", "sensitive": true },
    "defaultUserId": { "label": "Default Cloud userId", "placeholder": "shiuing" },
    "localRoot": { "label": "Local Root", "placeholder": "/Users/shiuing/.openclaw/workspace" },
    "timeoutMs": { "label": "HTTP Timeout (ms)" }
  }
}
